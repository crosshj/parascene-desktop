{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parascene",
  "version": "0.1.0",
  "identifier": "com.parascene.desktop",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1600,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 720,
        "maximized": true,
        "backgroundColor": [18, 18, 20, 255],
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https://www.parascene.com https://api.parascene.com ws: wss: http://localhost:* http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost media: http://media.localhost https: data: blob:; media-src 'self' asset: http://asset.localhost media: http://media.localhost https: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$VIDEO/**",
          "$HOME/Movies/**",
          "$HOME/Movies/Parascene/**",
          "$HOME/Movies/Parascene/Library/**",
          "$HOME/Movies/Parascene/Cache/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["parascene"]
      }
    }
  }
}
